
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_user_alpha_7';
    }
    function isCountryPartner() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'country_partner';
    }
    function isOwnerProfileUpdate(userId) {
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'photoURL']);
    }

    // Settings collection: Public read for app configuration, admin-only write.
    match /settings/{settingId} {
      allow read: if settingId == 'public' || (isSignedIn() && isAdmin());
      allow write: if isSignedIn() && isAdmin();
    }
    
    // Packages collection: Public read for pricing page, admin-only write.
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // Qualification tests: Public read for onboarding, admin-only write.
    match /qualification_tests/{testId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // Users collection
    match /users/{userId} {
      // User profiles are created by the authenticated server signup action.
      allow create: if false;
      // Allow read for owner or any admin
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // Owners can only update safe profile fields. Sensitive fields are admin-only.
      allow update: if isSignedIn() && (isAdmin() || isOwnerProfileUpdate(userId));
      // Allow delete only by admin
      allow delete: if isSignedIn() && isAdmin();
    }

    // Tasks and Responses
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /task_responses/{responseId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only the user who created it or an admin can read it
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && isAdmin();
    }
    
    // Chat sessions
    match /chats/{chatId} {
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }
    
    // Country Partners
    match /countryPartners/{partnerId} {
       allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
       allow create, update, delete: if isSignedIn() && isAdmin();
    }

    match /partner_applications/{applicationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /partner_transactions/{transactionId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.partnerUserId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /partner_wallet_funding_requests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.partnerUserId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /partner_wallet_logs/{logId} {
      allow read: if isSignedIn() && isAdmin();
      allow create, update, delete: if false;
    }

    // Deposits and Withdrawals
    match /deposits/{depositId} {
        allow create: if isSignedIn();
        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        allow update, delete: if isSignedIn() && isAdmin();
    }

    match /package_purchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }
    
    match /withdrawal_requests/{reqId} {
        allow create: if isSignedIn();
        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        allow update, delete: if isSignedIn() && isAdmin();
    }

    match /referral_transactions/{transactionId} {
      allow read: if isSignedIn() && (
        resource.data.referrerUserId == request.auth.uid ||
        resource.data.referredUserId == request.auth.uid ||
        isAdmin()
      );
      allow create, update, delete: if false;
    }
    
    // Generated Content
    match /generated_images/{imageId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isAdmin();
    }
    
    match /generated_videos/{videoId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /generated_music/{musicId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // User notifications
    match /user_notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

  }
}
